# Kody2 — Environment Configuration
# Copy this file to .env and adjust values for your environment.

# Application
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/kody2
APP_TIMEZONE=Africa/Cairo

# Database (XAMPP defaults)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=kody2
DB_CHARSET=utf8mb4
